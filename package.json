{
  "name": "ical-plugin-pro",
  "version": "2.1.1",
  "description": "iCal Pro with timezone support, incremental indexing, and multi-line task description.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "typecheck": "node ./node_modules/typescript/bin/tsc -noEmit -skipLibCheck",
    "test:smoke": "node ./node_modules/tsx/dist/cli.mjs --test scripts/smoke-tests.ts",
    "validate": "npm run typecheck && npm run test:smoke && npm run build"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "ical",
    "calendar"
  ],
  "author": "liuh886 (Customized from Andrew Brereton)",
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.10.1",
    "@typescript-eslint/parser": "^5.10.1",
    "builtin-modules": "^3.2.0",
    "esbuild": "^0.27.7",
    "obsidian": "latest",
    "tslib": "2.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
